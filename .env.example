# Vite build-time env vars (embedded into JS bundle at build time)
# Set these on Netlify via UI or CLI before deploying.
#
# Get these from your Supabase project dashboard:
#   Settings → API → Project URL + anon public key
#
# IMPORTANT: Do NOT put SUPABASE_SERVICE_ROLE_KEY or MISTRAL_API_KEY here.
# Those are server-side secrets that must stay in Supabase.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
