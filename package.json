{
  "name": "lecture-to-mastery",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "capture-screenshots": "node scripts/capture-screenshots.mjs",
    "aggregate": "npx tsx scripts/aggregate-reports.ts",
    "test:unit": "vitest run --config vitest.frontend.config.ts",
    "test:edge": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:edge && npm run test:e2e",
    "test:coverage": "vitest run --config vitest.frontend.config.ts --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-router": "^1.170.16",
    "@xyflow/react": "^12.11.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.22.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "html-to-image": "^1.11.13",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "puppeteer": "^25.3.0",
    "supabase": "^2.109.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  }
}
